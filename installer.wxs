<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product Id="*"
           Name="RLS Automacao VPN"
           Language="1033"
           Version="1.3.0.0"
           Manufacturer="RLS Automacao"
           UpgradeCode="{7A4E9C2F-3B1D-4E6A-8C5F-9D2B1A3E7F4C}">

    <Package InstallerVersion="301"
             Compressed="yes"
             InstallScope="perMachine"
             Platform="x64"
             Description="RLS Automacao VPN Client v1.3.0"
             Comments="Instala o cliente VPN da RLS Automacao com SoftEther incluido" />

    <!-- Upgrade: substitui versoes anteriores automaticamente -->
    <MajorUpgrade DowngradeErrorMessage="Uma versao mais recente ja esta instalada." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Icone RLS no Adicionar/Remover Programas -->
    <Icon Id="AppIcon.ico" SourceFile="src\icon.ico" />
    <Property Id="ARPPRODUCTICON"   Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK"      Value="https://github.com/danilohenriquesilvalira/VPN_Interface_C" />
    <Property Id="ARPURLINFOABOUT"  Value="https://github.com/danilohenriquesilvalira/VPN_Interface_C" />
    <Property Id="ARPCONTACT"       Value="RLS Automacao" />
    <Property Id="ARPCOMMENTS"      Value="Sistema VPN Industrial - RLS Automacao" />

    <!-- UI com branding RLS: banner (493x58) e dialog (493x312) -->
    <WixVariable Id="WixUIBannerBmp"  Value="src\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp"  Value="src\dialog.bmp" />

    <!-- Licenca (texto simples) -->
    <WixVariable Id="WixUILicenseRtf" Value="src\license.rtf" />

    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <Feature Id="ProductFeature" Title="RLS Automacao VPN" Level="1">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>

    <!--
      Custom action: instala SoftEther silenciosamente apos copia dos ficheiros.
      Execute="deferred" + Impersonate="no" = corre como SYSTEM (necessario para driver).
      Return="ignore" = nao falha o MSI se o SoftEther retornar codigo nao-zero.
    -->
    <CustomAction Id="InstallSoftEther"
                  FileKey="SEInstallerFile"
                  ExeCommand="/SILENT /NORESTART"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <!-- Apenas na primeira instalacao, nao em desinstalacao ou reparacao -->
      <Custom Action="InstallSoftEther" After="InstallFiles">NOT Installed AND NOT REMOVE</Custom>
    </InstallExecuteSequence>

  </Product>

  <!-- Estrutura de diretorios -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="RLS Automacao VPN" />
      </Directory>
      <Directory Id="DesktopFolder"   Name="Desktop" />
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="RLS Automacao VPN" />
      </Directory>
    </Directory>
  </Fragment>

  <!-- Componentes -->
  <Fragment>
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">

      <!-- Executavel principal -->
      <Component Id="MainExeComp" Guid="{3B1E5C7A-8D4F-2A6E-9C3B-5F7D1A2E8C4B}">
        <File Id="MainExeFile" Source="rls_vpn.exe" KeyPath="yes" />
      </Component>

      <!-- Instalador SoftEther (incluido no MSI) -->
      <Component Id="SEInstallerComp" Guid="{8C5F2A1E-4D7B-6E3C-A9F2-7B4D1C8E5A3F}">
        <File Id="SEInstallerFile" Source="se_client.exe" KeyPath="yes" />
      </Component>

      <!-- WebView2Loader.dll (WebView2 bootstrap DLL) -->
      <Component Id="WebView2LoaderComp" Guid="{1A3F7D9E-5C2B-4E8A-B6D4-2E9C5F1A7B3D}">
        <File Id="WebView2LoaderFile" Source="WebView2Loader.dll" KeyPath="yes" />
      </Component>

      <!-- Atalho no Ambiente de Trabalho -->
      <Component Id="DesktopShortcutComp" Guid="{2D8A4F7C-1E5B-3A9D-F6C2-4B8E1D7A5F9C}">
        <Shortcut Id="DesktopShortcut"
                  Directory="DesktopFolder"
                  Name="RLS Automacao VPN"
                  Description="Sistema VPN Industrial - RLS Automacao"
                  Target="[INSTALLFOLDER]rls_vpn.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon.ico" />
        <RegistryValue Root="HKCU"
                       Key="Software\RLS Automacao\VPN"
                       Name="DesktopShortcut"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Atalho no Menu Iniciar -->
      <Component Id="StartMenuShortcutComp" Guid="{6E3B9A5D-7F2C-4D8B-E1A4-9C5F2B7D3E8A}">
        <Shortcut Id="StartMenuShortcut"
                  Directory="AppMenuFolder"
                  Name="RLS Automacao VPN"
                  Description="Sistema VPN Industrial - RLS Automacao"
                  Target="[INSTALLFOLDER]rls_vpn.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon.ico" />
        <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\RLS Automacao\VPN"
                       Name="StartMenuShortcut"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
